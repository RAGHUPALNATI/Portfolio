<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Palnati Raghu Varma — AI & ML Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

/* ── LIGHT MODE VARIABLES ── */
:root{
  --bg:#ffffff; --bg2:#f8fafc; --bg3:#f1f5f9;
  --border:#e2e8f0;
  --text:#1e293b; --text2:#475569; --text3:#94a3b8;
  --blue-deep:#0a1628; --blue-mid:#1a3461;
  --blue-accent:#2563eb; --blue-light:#60a5fa; --blue-pale:#eff6ff;
  --card-bg:#ffffff; --card-border:#e2e8f0;
  --nav-bg:rgba(255,255,255,0.94);
  --input-bg:#ffffff;
  --hero-bg:linear-gradient(150deg,#ffffff 0%,#eff6ff 50%,#dbeafe 100%);
  --shadow-sm:0 1px 3px rgba(0,0,0,.08);
  --shadow-md:0 4px 20px rgba(37,99,235,.12);
  --shadow-lg:0 20px 60px rgba(37,99,235,.18);
  --radius:16px; --radius-sm:10px;
}

/* ── DARK MODE VARIABLES ── */
body.dark{
  --bg:#0f172a; --bg2:#1e293b; --bg3:#1e293b;
  --border:#334155;
  --text:#e2e8f0; --text2:#94a3b8; --text3:#64748b;
  --blue-deep:#e2e8f0; --blue-mid:#93c5fd;
  --blue-pale:#1e3a5f;
  --card-bg:#1e293b; --card-border:#334155;
  --nav-bg:rgba(15,23,42,0.95);
  --input-bg:#0f172a;
  --hero-bg:linear-gradient(150deg,#0f172a 0%,#1e293b 50%,#0f2444 100%);
  --shadow-sm:0 1px 3px rgba(0,0,0,.4);
  --shadow-md:0 4px 20px rgba(37,99,235,.25);
  --shadow-lg:0 20px 60px rgba(37,99,235,.3);
}

html{scroll-behavior:smooth}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;transition:background .35s,color .35s}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg3)}
::-webkit-scrollbar-thumb{background:var(--blue-accent);border-radius:3px}

/* ── DARK MODE TOGGLE ── */
#theme-toggle{
  position:fixed;bottom:5.2rem;right:1.5rem;z-index:990;
  width:46px;height:46px;border-radius:12px;border:none;cursor:pointer;
  background:linear-gradient(135deg,#2563eb,#1d4ed8);color:white;
  font-size:1.2rem;display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(37,99,235,.4);transition:all .3s;
}
#theme-toggle:hover{transform:translateY(-3px) rotate(20deg);box-shadow:0 8px 28px rgba(37,99,235,.55)}
body.dark #theme-toggle{background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 4px 20px rgba(245,158,11,.4)}
body.dark #theme-toggle:hover{box-shadow:0 8px 28px rgba(245,158,11,.55)}

/* ── PROGRESS BAR ── */
#progress-bar{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--blue-accent),var(--blue-light));z-index:2000;width:0;transition:width .1s}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:var(--nav-bg);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:box-shadow .3s,background .35s,border-color .35s}
nav.scrolled{box-shadow:0 4px 24px rgba(37,99,235,.1)}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:68px}
.nav-logo{font-weight:800;font-size:1.3rem;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-.5px;cursor:pointer}
.nav-links{display:flex;gap:0;list-style:none}
.nav-links a{display:block;padding:.5rem 1rem;color:var(--text2);font-size:.87rem;font-weight:500;text-decoration:none;border-radius:8px;transition:all .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:2px;left:50%;right:50%;height:2px;background:var(--blue-accent);border-radius:2px;transition:all .3s}
.nav-links a:hover,.nav-links a.active{color:var(--blue-accent);background:var(--blue-pale)}
.nav-links a.active::after{left:20%;right:20%}
.nav-hamburger{display:none;cursor:pointer;flex-direction:column;gap:5px}
.nav-hamburger span{width:24px;height:2px;background:var(--text);border-radius:2px;transition:all .3s}

/* ── HERO ── */
#home{min-height:100vh;background:var(--hero-bg);display:flex;align-items:center;padding:100px 2rem 60px;position:relative;overflow:hidden;transition:background .35s}
#home::before{content:'';position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 70%);top:-150px;right:-200px;pointer-events:none}
#home::after{content:'';position:absolute;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(37,99,235,.05) 0%,transparent 70%);bottom:-100px;left:-100px;pointer-events:none}
.hero-inner{max-width:1200px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.hero-text{animation:slideUp .8s ease both}
.hero-badge{display:inline-flex;align-items:center;gap:.5rem;background:var(--blue-pale);border:1px solid #bfdbfe;color:var(--blue-accent);font-size:.8rem;font-weight:600;padding:.4rem 1rem;border-radius:100px;margin-bottom:1.5rem;letter-spacing:.3px}
.hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--blue-accent);animation:pulseDot 1.8s infinite}
.hero-name{font-size:clamp(2.2rem,5vw,3.8rem);font-weight:900;line-height:1.1;color:var(--blue-deep);letter-spacing:-1.5px;margin-bottom:.8rem;transition:color .35s}
.hero-name span{background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-role{font-size:1.15rem;font-weight:600;color:var(--blue-mid);margin-bottom:1rem;min-height:1.8rem;transition:color .35s}
.hero-tagline{font-size:.98rem;color:var(--text2);line-height:1.7;max-width:460px;margin-bottom:2.5rem;transition:color .35s}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2.5rem}
.btn-primary{display:inline-flex;align-items:center;gap:.5rem;background:linear-gradient(135deg,var(--blue-accent),#1d4ed8);color:#fff;font-size:.9rem;font-weight:600;padding:.85rem 2rem;border-radius:100px;text-decoration:none;border:none;cursor:pointer;box-shadow:0 4px 20px rgba(37,99,235,.35);transition:all .25s;white-space:nowrap;font-family:'Poppins',sans-serif}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(37,99,235,.45)}
.btn-secondary{display:inline-flex;align-items:center;gap:.5rem;background:transparent;color:var(--blue-accent);font-size:.9rem;font-weight:600;padding:.85rem 2rem;border-radius:100px;text-decoration:none;border:2px solid var(--blue-accent);cursor:pointer;transition:all .25s;white-space:nowrap}
.btn-secondary:hover{background:var(--blue-pale);transform:translateY(-2px)}

/* ── SOCIAL ICONS ── */
.hero-socials{display:flex;gap:.8rem;flex-wrap:wrap}
.social-link{width:48px;height:48px;border-radius:14px;background:var(--card-bg);border:1.5px solid var(--card-border);display:flex;align-items:center;justify-content:center;color:var(--text2);font-size:1.1rem;text-decoration:none;transition:all .3s;box-shadow:var(--shadow-sm);position:relative;overflow:hidden}
.social-link svg,.social-link i{position:relative;z-index:1;transition:color .3s}
.social-link::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .3s;border-radius:inherit}
.social-link:hover{transform:translateY(-4px) scale(1.1);box-shadow:var(--shadow-lg)}
.social-link:hover svg,.social-link:hover i{color:white!important;fill:white!important}
.social-link:hover::before{opacity:1}
.social-link.linkedin::before{background:linear-gradient(135deg,#0077b5,#00a0dc)}
.social-link.linkedin:hover{border-color:#0077b5}
.social-link.github::before{background:linear-gradient(135deg,#24292e,#586069)}
.social-link.github:hover{border-color:#444}
.social-link.leetcode::before{background:linear-gradient(135deg,#f89f1b,#e67e00)}
.social-link.leetcode:hover{border-color:#f89f1b}
.social-link.email::before{background:linear-gradient(135deg,#ea4335,#ff7043)}
.social-link.email:hover{border-color:#ea4335}

/* ── BLOB ── */
.hero-image{display:flex;justify-content:center;align-items:center;animation:slideUp .8s .2s ease both}
.blob-wrap{position:relative;width:400px;height:400px}
.blob-bg{position:absolute;inset:0;background:linear-gradient(135deg,#dbeafe,#bfdbfe,#93c5fd);border-radius:62% 38% 46% 54%/60% 44% 56% 40%;animation:blobMorph 8s ease-in-out infinite}
body.dark .blob-bg{background:linear-gradient(135deg,#1e3a5f,#1e4080,#1a3461)}
.blob-ring{position:absolute;inset:-8px;border-radius:64% 36% 48% 52%/62% 42% 58% 38%;border:2px dashed rgba(37,99,235,.2);animation:blobMorph 8s 2s ease-in-out infinite;opacity:.6}
.blob-inner{position:absolute;inset:14px;border-radius:60% 40% 44% 56%/58% 46% 54% 42%;overflow:hidden;animation:blobMorph2 8s ease-in-out infinite;box-shadow:0 10px 40px rgba(37,99,235,.25)}
.blob-inner img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;filter:contrast(1.05) brightness(1.02)}
.blob-glow{position:absolute;inset:20px;border-radius:50%;background:radial-gradient(circle,rgba(37,99,235,.15) 0%,transparent 70%);animation:glowPulse 3s ease-in-out infinite;pointer-events:none}
.blob-deco{position:absolute;width:60px;height:60px;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));border-radius:16px;box-shadow:var(--shadow-lg);display:flex;align-items:center;justify-content:center;color:white;font-size:1.3rem}
.blob-deco-1{top:20px;right:-15px;animation:floatY 3s ease-in-out infinite}
.blob-deco-2{bottom:50px;left:-15px;animation:floatY 3s 1s ease-in-out infinite;background:linear-gradient(135deg,#1d4ed8,var(--blue-accent))}
.blob-deco-3{bottom:-10px;right:50px;animation:floatY 3s 2s ease-in-out infinite;width:50px;height:50px;font-size:1rem;background:linear-gradient(135deg,var(--blue-light),#93c5fd)}

/* ── SECTIONS ── */
section{padding:100px 2rem;transition:background .35s}
.section-inner{max-width:1200px;margin:0 auto}
.section-tag{font-size:.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue-accent);margin-bottom:.75rem}
.section-title{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:var(--blue-deep);letter-spacing:-1px;line-height:1.2;margin-bottom:1rem;transition:color .35s}
.section-sub{font-size:1rem;color:var(--text2);max-width:600px;line-height:1.7;transition:color .35s}
.section-divider{width:60px;height:4px;background:linear-gradient(90deg,var(--blue-accent),var(--blue-light));border-radius:4px;margin:1.5rem 0}

/* ── ABOUT ── */
#about{background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;margin-top:3rem}
.about-text p{font-size:.98rem;color:var(--text2);line-height:1.9;margin-bottom:1.5rem}
.edu-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:1.5rem;display:flex;gap:1rem;align-items:flex-start;box-shadow:var(--shadow-sm);transition:all .3s;margin-bottom:1rem}
.edu-card:hover{box-shadow:var(--shadow-md);transform:translateY(-3px)}
.edu-icon{width:52px;height:52px;border-radius:14px;flex-shrink:0;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));display:flex;align-items:center;justify-content:center;color:white;font-size:1.3rem}
.edu-label{font-size:.75rem;color:var(--blue-accent);font-weight:600;text-transform:uppercase;letter-spacing:1px}
.edu-degree{font-size:1rem;font-weight:700;color:var(--blue-deep);margin:.2rem 0;transition:color .35s}
.edu-school{font-size:.88rem;color:var(--text2)}
.edu-year{font-size:.82rem;color:var(--text3);margin-top:.3rem;display:flex;align-items:center;gap:.4rem}
.about-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.stat-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:1.5rem;text-align:center;box-shadow:var(--shadow-sm);transition:all .3s}
.stat-card:hover{box-shadow:var(--shadow-md);transform:translateY(-3px)}
.stat-num{font-size:2.2rem;font-weight:900;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat-label{font-size:.82rem;color:var(--text2);font-weight:500;margin-top:.2rem}

/* ── SKILLS ── */
#skills{background:var(--bg)}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;margin-top:3rem}
.skill-category{background:var(--bg2);border:1px solid var(--card-border);border-radius:var(--radius);padding:1.8rem;transition:all .3s}
.skill-category:hover{box-shadow:var(--shadow-md);transform:translateY(-4px);border-color:#bfdbfe}
.skill-cat-header{display:flex;align-items:center;gap:.8rem;margin-bottom:1.5rem}
.skill-cat-icon{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));display:flex;align-items:center;justify-content:center;color:white;font-size:1.1rem}
.skill-cat-name{font-size:1rem;font-weight:700;color:var(--blue-deep);transition:color .35s}
.skill-list{display:flex;flex-direction:column;gap:.9rem}
.skill-row{display:flex;justify-content:space-between;margin-bottom:.4rem}
.skill-name{font-size:.85rem;font-weight:500;color:var(--text)}
.skill-pct{font-size:.8rem;color:var(--blue-accent);font-weight:600;font-family:'Space Mono',monospace}
.skill-bar{height:7px;background:var(--border);border-radius:10px;overflow:hidden}
.skill-fill{height:100%;border-radius:10px;background:linear-gradient(90deg,var(--blue-accent),var(--blue-light));transition:width 1.5s cubic-bezier(.4,0,.2,1);width:0}
.skill-tags{display:flex;flex-wrap:wrap;gap:.5rem}
.skill-tag{background:var(--blue-pale);color:var(--blue-accent);font-size:.78rem;font-weight:600;padding:.3rem .8rem;border-radius:100px;border:1px solid #bfdbfe}
body.dark .skill-tag{background:rgba(37,99,235,.15);border-color:rgba(37,99,235,.3);color:var(--blue-light)}

/* ── PROJECTS ── */
#projects{background:var(--bg2)}
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.8rem;margin-top:3rem}
.project-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);overflow:hidden;transition:all .35s cubic-bezier(.4,0,.2,1);box-shadow:var(--shadow-sm)}
.project-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg);border-color:#bfdbfe}
.project-thumb{height:180px;display:flex;align-items:center;justify-content:center;font-size:4rem;position:relative;overflow:hidden}
.pt-1{background:linear-gradient(135deg,#dbeafe,#bfdbfe)}
.pt-2{background:linear-gradient(135deg,#d1fae5,#a7f3d0)}
.pt-3{background:linear-gradient(135deg,#fce7f3,#fbcfe8)}
.pt-4{background:linear-gradient(135deg,#ede9fe,#ddd6fe)}
.project-body{padding:1.6rem}
.project-num{font-size:.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue-accent);margin-bottom:.5rem}
.project-title{font-size:1.15rem;font-weight:800;color:var(--blue-deep);margin-bottom:.75rem;transition:color .35s}
.project-desc{font-size:.88rem;color:var(--text2);line-height:1.7;margin-bottom:1.2rem}
.project-meta{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.3rem}
.meta-chip{background:var(--blue-pale);color:var(--blue-mid);font-size:.75rem;font-weight:600;padding:.28rem .7rem;border-radius:6px;display:flex;align-items:center;gap:.3rem;transition:all .35s}
body.dark .meta-chip{background:rgba(37,99,235,.2);color:#93c5fd}
.project-footer{display:flex;align-items:center;justify-content:space-between}
.accuracy-badge{font-size:.8rem;font-weight:700;color:#059669;background:#d1fae5;padding:.3rem .8rem;border-radius:8px}
body.dark .accuracy-badge{background:rgba(5,150,105,.2);color:#34d399}
.project-link{display:inline-flex;align-items:center;gap:.4rem;color:var(--blue-accent);font-size:.85rem;font-weight:600;text-decoration:none;padding:.4rem .9rem;border:1.5px solid var(--blue-accent);border-radius:8px;transition:all .25s}
.project-link:hover{background:var(--blue-accent);color:white;transform:scale(1.05)}

/* ── ACHIEVEMENTS ── */
#achievements{background:var(--bg)}
.ach-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;margin-top:3rem}
.ach-card{background:linear-gradient(135deg,#0a1628 0%,#1a3461 100%);border-radius:var(--radius);padding:2rem;color:white;position:relative;overflow:hidden;transition:all .3s}
.ach-card::before{content:'';position:absolute;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04);right:-60px;top:-60px}
.ach-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg)}
.ach-icon{font-size:2rem;margin-bottom:1rem}
.ach-title{font-size:1.05rem;font-weight:700;margin-bottom:.5rem}
.ach-desc{font-size:.85rem;opacity:.75;line-height:1.6}
.ach-link{display:inline-flex;align-items:center;gap:.4rem;color:var(--blue-light);font-size:.82rem;font-weight:600;text-decoration:none;margin-top:.8rem;transition:opacity .2s}
.ach-link:hover{opacity:.8}

/* ── CERTIFICATIONS ── */
#certifications{background:var(--bg2)}
.cert-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.2rem;margin-top:3rem}
.cert-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius-sm);padding:1.3rem 1.5rem;display:flex;align-items:center;gap:1rem;transition:all .25s;box-shadow:var(--shadow-sm);text-decoration:none;color:inherit}
.cert-card:hover{box-shadow:var(--shadow-md);transform:translateX(5px);border-color:#bfdbfe}
.cert-icon{width:48px;height:48px;border-radius:12px;flex-shrink:0;background:linear-gradient(135deg,var(--blue-pale),#bfdbfe);display:flex;align-items:center;justify-content:center;font-size:1.3rem}
body.dark .cert-icon{background:linear-gradient(135deg,#1e3a5f,#1e4080)}
.cert-name{font-size:.9rem;font-weight:600;color:var(--blue-deep);transition:color .35s}
.cert-issuer{font-size:.8rem;color:var(--text3);margin-top:.2rem}
.cert-verify{font-size:.75rem;color:var(--blue-accent);font-weight:600;margin-top:.3rem;display:flex;align-items:center;gap:.3rem}

/* ── CONTACT ── */
#contact{background:var(--bg)}
.contact-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:4rem;margin-top:3rem;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:1.2rem}
.contact-item{display:flex;align-items:center;gap:1rem;background:var(--bg2);border:1px solid var(--card-border);border-radius:var(--radius-sm);padding:1.1rem 1.3rem;transition:all .25s;text-decoration:none;color:inherit}
.contact-item:hover{border-color:var(--blue-accent);box-shadow:var(--shadow-md);transform:translateX(4px)}
.contact-icon{width:42px;height:42px;border-radius:10px;flex-shrink:0;background:linear-gradient(135deg,var(--blue-accent),var(--blue-light));display:flex;align-items:center;justify-content:center;color:white;font-size:1rem}
.contact-label{font-size:.75rem;color:var(--text3);font-weight:500}
.contact-val{font-size:.9rem;color:var(--text);font-weight:600}
.contact-form{background:var(--bg2);border:1px solid var(--card-border);border-radius:var(--radius);padding:2rem}
.form-group{margin-bottom:1.3rem}
.form-group label{display:block;font-size:.85rem;font-weight:600;color:var(--text);margin-bottom:.5rem}
.form-group input,.form-group textarea{width:100%;padding:.85rem 1rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:'Poppins',sans-serif;font-size:.9rem;color:var(--text);background:var(--input-bg);transition:border-color .2s,background .35s,color .35s;outline:none;resize:vertical}
.form-group input:focus,.form-group textarea:focus{border-color:var(--blue-accent);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
.form-group textarea{min-height:120px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
#form-msg{font-size:.85rem;margin-top:.75rem;font-weight:500;display:none;padding:.7rem 1rem;border-radius:8px}
#form-msg.success{color:#059669;background:#d1fae5;display:block}
#form-msg.error{color:#dc2626;background:#fee2e2;display:block}

/* ── FOOTER ── */
footer{background:#020a18;color:rgba(255,255,255,.7);padding:2.5rem 2rem;text-align:center}
body.dark footer{background:#020810}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-logo{font-size:1.5rem;font-weight:900;letter-spacing:-.5px;background:linear-gradient(135deg,var(--blue-light),#93c5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:1rem}
.footer-links{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem}
.footer-links a{color:rgba(255,255,255,.6);font-size:.85rem;text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--blue-light)}
.footer-socials{display:flex;justify-content:center;gap:.8rem;margin-bottom:1.5rem}
.footer-socials a{width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.7);display:flex;align-items:center;justify-content:center;text-decoration:none;transition:all .2s}
.footer-socials a:hover{background:var(--blue-accent);color:white;transform:translateY(-2px)}
.footer-copy{font-size:.8rem;opacity:.5}

/* ── BACK TO TOP ── */
#back-top{position:fixed;bottom:1.5rem;right:1.5rem;width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,var(--blue-accent),#1d4ed8);color:white;font-size:1.1rem;display:flex;align-items:center;justify-content:center;text-decoration:none;opacity:0;pointer-events:none;transition:all .3s;box-shadow:var(--shadow-md);z-index:900}
#back-top.show{opacity:1;pointer-events:auto}
#back-top:hover{transform:translateY(-3px)}

/* ── ANIMATIONS ── */
@keyframes slideUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes blobMorph{0%,100%{border-radius:62% 38% 46% 54%/60% 44% 56% 40%}25%{border-radius:44% 56% 62% 38%/54% 62% 38% 46%}50%{border-radius:54% 46% 38% 62%/46% 38% 62% 54%}75%{border-radius:38% 62% 54% 46%/38% 54% 46% 62%}}
@keyframes blobMorph2{0%,100%{border-radius:60% 40% 44% 56%/58% 46% 54% 42%}50%{border-radius:42% 58% 60% 40%/44% 60% 40% 56%}}
@keyframes floatY{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-14px) rotate(5deg)}}
@keyframes glowPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.1)}}
@keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.6)}}
@keyframes cursorBlink{0%,100%{opacity:1}50%{opacity:0}}
.cursor{display:inline-block;animation:cursorBlink .7s infinite;color:var(--blue-accent)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.12s}
.reveal-delay-2{transition-delay:.22s}
.reveal-delay-3{transition-delay:.32s}



/* ── RESPONSIVE ── */
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;text-align:center;gap:3rem}
  .hero-text{order:2}.hero-image{order:1}
  .hero-tagline,.hero-btns,.hero-socials{justify-content:center;margin-left:auto;margin-right:auto}
