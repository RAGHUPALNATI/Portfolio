<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
(function() {
  /* ── CV DATA ── */
  var CV_B64 = "";

  /* ── DARK MODE ── */
  var toggle = document.getElementById('theme-toggle');
  function applyTheme(dark) {
    if (dark) {
      document.body.classList.add('dark');
      toggle.innerHTML = '&#9728;&#65039;';
    } else {
      document.body.classList.remove('dark');
      toggle.innerHTML = '&#127769;';
    }
  }
  applyTheme(localStorage.getItem('theme') === 'dark');
  toggle.addEventListener('click', function() {
    var isDark = document.body.classList.contains('dark');
    applyTheme(!isDark);
    localStorage.setItem('theme', !isDark ? 'dark' : 'light');
  });

  /* ── NAV SCROLL & ACTIVE ── */
  var navbar = document.getElementById('navbar');
  var backTop = document.getElementById('back-top');
  var progressBar = document.getElementById('progress-bar');
  var sections = document.querySelectorAll('section[id]');
  var navLinks = document.querySelectorAll('.nav-links a');
  window.addEventListener('scroll', function() {
    var sy = window.scrollY;
    var dh = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.width = (sy / dh * 100) + '%';
    navbar.classList.toggle('scrolled', sy > 50);
    backTop.classList.toggle('show', sy > 400);
    var cur = '';
    sections.forEach(function(s) { if (sy >= s.offsetTop - 100) cur = s.id; });
    navLinks.forEach(function(a) { a.classList.toggle('active', a.getAttribute('href') === '#' + cur); });
  });

  /* ── HAMBURGER ── */
  document.getElementById('hamburger').addEventListener('click', function() {
    document.getElementById('navLinks').classList.toggle('open');
  });

  /* ── NAV LINKS — explicit smooth scroll ── */
  navLinks.forEach(function(a) {
    a.addEventListener('click', function(e) {
      var href = a.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        document.getElementById('navLinks').classList.remove('open');
        var targetId = href.slice(1);
        var target = document.getElementById(targetId);
        if (target) {
          var offset = 68; // navbar height
          var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({ top: top, behavior: 'smooth' });
        }
      }
    });
  });

  /* ── NAV LOGO ── */
  document.getElementById('nav-logo-click').addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });

  /* ── ALL anchor #hash links (footer, buttons) ── */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    if (navLinks && Array.prototype.indexOf.call(navLinks, a) !== -1) return; // already handled above
    a.addEventListener('click', function(e) {
      var href = a.getAttribute('href');
      if (href && href.length > 1) {
        e.preventDefault();
        var target = document.getElementById(href.slice(1));
        if (target) {
          var top = target.getBoundingClientRect().top + window.pageYOffset - 68;
          window.scrollTo({ top: top, behavior: 'smooth' });
        }
      }
    });
  });

  /* ── REVEAL ON SCROLL ── */
  var revealObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(function(el) { revealObs.observe(el); });

  /* ── SKILL BARS ── */
  var barObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.skill-fill').forEach(function(b) { b.style.width = b.dataset.w + '%'; });
        barObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.skill-category').forEach(function(c) { barObs.observe(c); });

  /* ── TYPING ANIMATION ── */
  var roles = ['AI & ML Student', 'Future Data Scientist', 'ML Engineer', 'Problem Solver', 'Java Developer'];
  var ri = 0, ci = 0, deleting = false;
  var roleEl = document.getElementById('typed-role');
  function type() {
    var cur = roles[ri];
    if (!deleting) {
      roleEl.innerHTML = cur.slice(0, ++ci) + '<span class="cursor">|</span>';
      if (ci === cur.length) { deleting = true; setTimeout(type, 1800); return; }
    } else {
      roleEl.innerHTML = cur.slice(0, --ci) + '<span class="cursor">|</span>';
      if (ci === 0) { deleting = false; ri = (ri + 1) % roles.length; }
    }
    setTimeout(type, deleting ? 60 : 100);
  }
  type();

  /* ── DOWNLOAD CV ── */
  document.getElementById('dl-cv-btn').addEventListener('click', function() {
    try {
      var bytes = atob(CV_B64);
      var arr = new Uint8Array(bytes.length);
      for (var i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);
      var blob = new Blob([arr], {type:'application/vnd.openxmlformats-officedocument.wordprocessingml.document'});
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = 'Palnati_Raghu_Varma_CV.docx';
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      setTimeout(function() { URL.revokeObjectURL(url); }, 1000);
    } catch(e) { alert('Download failed. Please try again.'); }
  });

  /* ── CONTACT FORM — mailto (works everywhere, zero setup) ── */
  document.getElementById('send-btn').addEventListener('click', function() {
    var name    = document.getElementById('f-name').value.trim();
    var email   = document.getElementById('f-email').value.trim();
    var subject = document.getElementById('f-subject').value.trim();
    var msg     = document.getElementById('f-msg').value.trim();
    var out     = document.getElementById('form-msg');

    out.className = ''; out.style.display = 'none';

    if (!name || !email || !msg) {
      out.textContent = '⚠ Please fill in all required fields.';
      out.className = 'error'; return;
    }
    if (!/[^\s@]+@[^\s@]+\.[^\s@]+/.test(email)) {
      out.textContent = '⚠ Please enter a valid email address.';
      out.className = 'error'; return;
    }

    var finalSubject = subject || 'Portfolio Contact from ' + name;
    var body = 'Name: ' + name + '\nEmail: ' + email + '\n\n' + msg;

    var mailtoLink = 'mailto:raghuvarmapalnati@gmail.com'
      + '?subject=' + encodeURIComponent(finalSubject)
      + '&body=' + encodeURIComponent(body);

    window.location.href = mailtoLink;

    out.textContent = '✅ Your email client has opened! Hit Send to deliver your message.';
    out.className = 'success';
    ['f-name','f-email','f-subject','f-msg'].forEach(function(id) {
      document.getElementById(id).value = '';
    });
    setTimeout(function() { out.style.display = 'none'; }, 7000);
  });


})();
</script>

